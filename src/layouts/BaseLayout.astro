---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "全国矫正机构资料档案" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main class="page-shell">
      <slot />
    </main>
  </body>
</html>
